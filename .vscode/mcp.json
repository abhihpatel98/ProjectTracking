{
	"servers": {
		"sql-mcp-server": {
			"type": "stdio",
			"command": "dotnet",
			"args": [
				"tool",
				"run",
				"dab",
				"start",
				"--mcp-stdio",
				"role:anonymous",
				"--config",
				"./ProjectTrackingApp/dab-config.json"
			]
		},
		"github-mcp-server": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp"
		},
		"project-tracking-app-repo-mcp-server": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"C:/Personal Repos/MCP Demo/ProjectTrackingDemo/ProjectTrackingApp"
			],
			"type": "stdio"
		},
		"project-tracking-app-mcp-server": {
			"type": "stdio",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"./ProjectTrackingMCP/ProjectTrackingMCP.csproj",
			]
		}
	}
}